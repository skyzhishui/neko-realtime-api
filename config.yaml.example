# ============================================================
# neko-realtime-api 配置文件示例
# ============================================================
# 复制此文件为 config.yaml 并根据实际环境修改配置值
# 所有 IP 地址需替换为实际服务地址，端口需替换为实际端口
# ============================================================

# ------------------------------------------------------------
# 实时服务器配置
# ------------------------------------------------------------
realtime_server:
  # 服务监听地址，0.0.0.0 表示监听所有网卡
  host: 0.0.0.0

  # 服务监听端口
  port: 8765

  # 是否启用认证（旧字段，建议使用 security.auth_enabled）
  # 启用后客户端连接需携带 Bearer Token
  auth_enabled: false

  # 认证令牌（旧字段，建议使用 security.auth_token）
  # 当 auth_enabled=true 时生效
  # 客户端需在 WebSocket 连接时通过 Authorization 头传入
  # 留空表示必须通过 security.auth_token 设置
  auth_token: ""

  # 默认工作模式
  # - asr_llm:    A模式（ASR+LLM模式），先 ASR 转文字再送 LLM，兼容性更好
  # - omni_audio: B模式（全双工模式），音频直接送入 Omni 模型，延迟更低
  default_mode: asr_llm

  # Omni 连续错误次数阈值，超过后自动降级到 A模式
  # 设为 0 可禁用自动降级
  omni_error_threshold: 3

  # 降级持续时间（秒），A模式降级后经过此时间会尝试恢复 B模式
  fallback_duration_s: 60

# ------------------------------------------------------------
# 安全配置
# ------------------------------------------------------------
security:
  # 是否启用认证，启用后客户端连接需携带 Bearer Token
  # 当 auth_enabled=true 且 auth_token 为空时，服务拒绝启动
  auth_enabled: true

  # 认证令牌，当 auth_enabled=true 时生效
  # 客户端需在 WebSocket 连接时通过 Authorization: Bearer <auth_token> 头传入
  # ⚠️ 必须设置为非空字符串，否则服务拒绝启动
  auth_token: ""

  # 允许的跨域来源列表（CORS）
  # 空列表表示允许所有来源
  # 示例: ["https://example.com", "https://app.example.com"]
  allowed_origins: []

  # 单个音频帧 base64 编码后的最大字节数（5MB）
  max_audio_frame_b64_bytes: 5242880

  # 单个图片 base64 编码后的最大字节数（10MB）
  max_image_b64_bytes: 10485760

  # 单个会话最大对话条目数
  max_conversation_items: 200

  # 单个会话最大音频时长（秒）
  max_session_audio_seconds: 600

# ------------------------------------------------------------
# VAD（语音活动检测）配置
# ------------------------------------------------------------
vad:
  # VAD 引擎类型
  # - silero: 使用 Silero VAD 模型
  engine: silero

  # 语音检测阈值（0.0~1.0），值越高要求越严格
  # - 较低值（0.3~0.5）: 更灵敏，容易误触发，适合安静环境
  # - 较高值（0.6~0.8）: 更保守，减少误触发，适合嘈杂环境
  threshold: 0.5

  # 静音超时时间（毫秒），检测到持续静音后判定用户说完
  # - 较短值（300~400ms）: 响应更快，但可能打断思考停顿
  # - 较长值（500~700ms）: 容忍更长的思考停顿
  silence_timeout_ms: 500

  # 最短语音时长（毫秒），短于此时间的语音片段将被忽略（过滤噪声）
  min_speech_duration_ms: 200

  # 最大音频时长（毫秒），超过后强制截断并触发处理
  # 防止用户长时间说话导致内存溢出
  max_audio_duration_ms: 30000

  # 前缀填充时长（毫秒），语音开始前保留的音频缓冲
  # 用于避免语音开头被截断（吞字问题）
  prefix_padding_ms: 300

  # 音频采样率（Hz），通常为 16000
  sample_rate: 16000

  # Silero VAD 模型目录路径
  # 指向包含 silero_vad.onnx 的目录
  # 设为 null 则使用 modelscope 缓存目录自动下载
  silero_model_path: ./models/silero-vad

  # 是否启用 Smart Turn v3.2 话轮结束检测
  # 启用后，静音超时时会进行二次判断：
  #   - Complete: 用户说完了，触发 speech_stopped
  #   - Incomplete: 用户在思考/犹豫，重置静音计数继续等待
  # 禁用则直接根据静音超时判定
  smart_turn_enabled: true

  # Smart Turn 模型目录路径
  # 指向包含 smart-turn-v3.2-gpu.onnx 的目录
  # 设为 null 则使用 modelscope 缓存目录自动下载
  smart_turn_path: ./models/smart-turn-v3

  # Smart Turn 话轮结束判断阈值（0.0~1.0）
  # sigmoid 输出 > threshold 判定为 Complete（用户说完了）
  # - 较低值（0.3~0.4）: 更容易判定为说完了，响应更快
  # - 较高值（0.5~0.6）: 更保守，容忍更长的停顿
  smart_turn_threshold: 0.5

# ------------------------------------------------------------
# 外部服务配置
# ------------------------------------------------------------
services:
  # ---- Omni 多模态模型服务（A和B模式通用） ----
  omni:
    # Omni API 基础地址（兼容 OpenAI Chat Completions 接口）
    # 需包含 /v1 前缀，如 http://localhost:8000/v1
    base_url: http://localhost:8000/v1

    # 模型名称，需与后端实际部署的模型一致
    model: Qwen3-Omni

    # API Key（可选），用于 OpenAI 兼容接口认证
    # 设为 null 或不设置则不发送 Authorization 头（适用于内网无认证部署）
    # 设为字符串则自动添加 Authorization: Bearer <api_key> 头
    api_key: null

    # 请求超时时间（秒）
    timeout_s: 30

    # 最大生成 token 数
    max_tokens: 4096

    # 生成温度（0.0~2.0），值越高输出越随机
    temperature: 0.7

    # 重复惩罚（>1.0 抑制重复），值越大惩罚越强
    repetition_penalty: 1.2

  # ---- ASR 语音识别服务 ----
  asr:
    # 远程 ASR API 基础地址（local_asr=false 时使用）
    # 兼容 OpenAI Whisper 接口: POST {base_url}/audio/transcriptions
    # 设为 null 则禁用远程 ASR
    base_url: null

    # ASR 模型名称
    model: SenseVoiceSmall

    # 识别语言代码
    # - zh: 中文
    # - en: 英文
    # - ja: 日文
    # - auto: 自动检测
    language: zh

    # ASR 请求超时时间（秒）
    timeout_s: 10

    # 是否使用 WebSocket 方式调用远程 ASR（而非 HTTP）
    # - false: HTTP 方式，POST 音频文件，延迟约 260ms（2s 音频）
    # - true:  WebSocket 方式，流式发送 PCM，适合长音频
    use_ws: false

    # 是否使用本地 ASR 引擎（sherpa-onnx + SenseVoice-Small ONNX 推理）
    # - true:  本地推理，需安装 sherpa-onnx，启动时预加载模型
    # - false: 使用远程 ASR 服务（通过 base_url 调用）
    local_asr: true

    # 本地 ASR 推理设备
    # - cpu: 使用 CPU 推理（默认，当前 sherpa-onnx pip 包为 CPU-only）
    # - cuda: 使用 GPU 推理（需从源码编译 sherpa-onnx 并启用 GPU 支持）
    # 注意：sherpa-onnx pip 安装包为 CPU-only，设置 cuda 会回退到 cpu 并输出警告
    device: cpu

    # 本地 ASR 模型路径（仅 local_asr=true 时生效）
    # 指向 sherpa-onnx SenseVoice-Small 模型目录，需包含：
    #   model_q8.onnx (Q8 量化模型，优先使用)
    #   model.onnx (FP32 模型，备选)
    #   tokens.txt (词表文件)
    # 设为 null 则使用默认路径 ./models
    # 首次启动时自动从 ModelScope 下载 xiaowangge/sherpa-onnx-sense-voice-small
    # ⚠️ 用户需根据实际部署路径修改
    asr_model_path: ./models/sherpa-onnx-sense-voice-small

  # ---- TTS 语音合成服务 ----
  # 支持三种 TTS 后端，通过 model 字段切换:
  #   Qwen3-TTS: 预设音色 + 声音克隆，24kHz 输出
  #   voxcpm2:   零样本/声音克隆 + 内联情感指令，48kHz 输出（自动降采样到 24kHz）
  #   gsv-tts-lite: 音色风格解耦的语音克隆，32kHz 输出
  tts:
    # TTS HTTP API 基础地址
    # 兼容 OpenAI Speech 接口: POST {base_url}/audio/speech
    # 需包含 /v1 前缀，如 http://localhost:8091/v1
    base_url: http://localhost:8091/v1

    # TTS WebSocket 流式地址（mode=ws 时使用）
    # 逐字流式合成，首音频延迟更低
    ws_url: ws://localhost:8091/v1/audio/speech/stream

    # TTS 调用模式
    # - http: 分句 HTTP 模式，LLM 输出按标点分句后逐句请求 TTS
    # - ws:   WebSocket 逐字流式模式，LLM 每个 token 即时送 TTS
    # Qwen3-TTS 和 VoxCPM2 均支持 http 和 ws 两种模式
    mode: http

    # TTS 模型名称（决定使用哪个 TTS 后端）
    # - Qwen3-TTS:    基于 vllm-omni 的 Qwen3-TTS，预设音色（vivian/ryan 等）+ 声音克隆
    # - voxcpm2:      基于 vllm-omni 的 VoxCPM2，零样本合成 + 声音克隆 + 内联情感指令
    # - gsv-tts-lite: GSV-TTS-Lite 音色风格解耦（需额外配置 gsv_tts 节）
    model: Qwen3-TTS

    # API Key（可选），用于 OpenAI 兼容接口认证
    # 设为 null 或不设置则不发送 Authorization 头（适用于内网无认证部署）
    # 设为字符串则自动添加 Authorization: Bearer <api_key> 头
    # HTTP 模式和 WebSocket 模式均使用此 key
    api_key: null

    # 默认音色名称（可被客户端 session.update 覆盖）
    # Qwen3-TTS 预设音色: vivian, serena, sohee, ono_anna, ryan, aiden, dylan, eric, uncle_fu
    # VoxCPM2: 填 "default"（零样本模式，音色由 ref_audio 或内联指令决定）
    voice: vivian

    # 音频输出格式（固定 pcm，用于实时流式）
    response_format: pcm

    # 是否启用流式输出（固定 true）
    stream: true

    # 流式输出格式（固定 audio）
    stream_format: audio

    # TTS 语言设置
    # - Chinese: 中文
    # - English: 英文
    # - Japanese: 日文
    language: Chinese

    # TTS 输出采样率（Hz）
    # Qwen3-TTS 固定输出 24000Hz，VoxCPM2 输出 48000Hz 后自动降采样到 24000Hz
    sample_rate: 24000

    # TTS 请求超时时间（秒）
    timeout_s: 15

    # ---- 声音克隆配置（Qwen3-TTS 和 VoxCPM2 通用） ----
    # 留空或设为 null 则不使用声音克隆，使用预设音色或零样本模式
    # ref_audio: 参考音频文件路径或 URL
    #   - 本地文件路径: /path/to/reference.wav（自动读取并转 base64 data URL）
    #   - HTTP URL: https://example.com/reference.wav（直接传递）
    #   - Base64 data URL: data:audio/wav;base64,...（直接传递）
    #   - 要求: 3~30 秒清晰语音，24kHz 单声道（Qwen3-TTS）/ 任意采样率（VoxCPM2）
    # ref_text: 参考音频对应的转录文本
    #   - Qwen3-TTS: 可选（不传则仅用参考音频音色）
    #   - VoxCPM2:   可选（传了则启用终极克隆模式，克隆效果最强）
    ref_audio: null
    ref_text: null

  # ---- GSV-TTS-Lite 语音克隆 TTS 配置 ----
  # 当 services.tts.model = gsv-tts-lite 时使用此配置
  # GSV-TTS-Lite 使用 HTTP POST + SSE（非 WebSocket，mode 固定为 http）
  # 音频输出: int16 PCM 32kHz，自动重采样到 tts_pipeline.output_sample_rate
  # 特性: 音色风格解耦（speaker_audio + prompt_audio）、自动 ASR
  gsv_tts:
    # GSV-TTS-Lite API 基础地址
    base_url: http://localhost:8001

    # 说话人参考音频路径（控制音色/谁在说话）
    # 支持本地文件路径或 HTTP/HTTPS URL
    # ⚠️ 用户需根据实际部署路径修改
    speaker_audio: ""

    # 提示参考音频路径（控制风格/情感/怎么说）
    # 支持本地文件路径或 HTTP/HTTPS URL
    # ⚠️ 用户需根据实际部署路径修改
    prompt_audio: ""

    # 提示文本（对应 prompt_audio 的文字内容）
    # 为空时自动使用 ASR 识别 prompt_audio 的内容
    prompt_text: ""

    # 音频输出采样率（Hz）
    sample_rate: 32000

    # HTTP 请求超时（秒）
    timeout_s: 30

    # 语速倍率
    speed: 1.0

# ------------------------------------------------------------
# TTS 参考音频配置
# ------------------------------------------------------------
tts:
  # 参考音频文件目录（用于声音克隆时存放参考音频）
  # ⚠️ 用户需根据实际部署路径修改
  ref_audio_dir: ./ref_audio

  # 允许的参考音频来源主机列表（空列表表示允许所有）
  # 示例: ["example.com", "cdn.example.com"]
  allowed_ref_audio_hosts: []

  # 参考音频文件最大字节数（50MB）
  max_ref_audio_bytes: 52428800

# ------------------------------------------------------------
# TTS 管线配置（控制 TTS 输出的后处理行为）
# ------------------------------------------------------------
tts_pipeline:
  # 最小子句长度（字符数），LLM 输出文本按标点分句时
  # 短于此长度的子句不会单独送 TTS，会等待更多文本累积
  # - 较小值（4~6）: 更快开始合成，但可能断句不自然
  # - 较大值（8~12）: 更自然的断句，但首音频延迟略增
  min_sub_sentence_len: 6

  # 最大并发 TTS 请求数
  max_concurrent_tts: 2

  # 是否对 TTS 输出进行重采样
  # - true:  将 TTS 输出重采样到 output_sample_rate（可能降低音质）
  # - false: 保持 TTS 原始采样率输出（推荐，音质最佳）
  resample_output: false

  # 重采样目标采样率（仅 resample_output=true 时生效）
  # 如果 TTS 输出 24000Hz 但客户端需要 16000Hz，可启用重采样
  output_sample_rate: 24000
